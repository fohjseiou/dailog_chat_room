# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/legal_consultation
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/legal_consultation

# DashScope / Qwen
# Get your API key from https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

# OpenAI (optional, for multi-provider support)
# OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4

# LLM Provider selection (tongyi | openai)
LLM_PROVIDER=tongyi

# ChromaDB
CHROMA_DB_PATH=./data/chroma
CHROMA_COLLECTION_NAME=legal_knowledge
CHROMA_PERSISTENT_STORAGE=true

# App
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
CORS_ORIGINS=http://localhost:5173

# Summary Settings
SUMMARY_MESSAGE_THRESHOLD=10
SUMMARY_TOKEN_THRESHOLD=8000

# Auth
# IMPORTANT: Generate a secure key with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Do NOT use the placeholder value below in production!
SECRET_KEY=your-secure-secret-key-min-32-characters-long
PASSWORD_MIN_LENGTH=6
JWT_EXPIRE_DAYS=7

# Memory
SHORT_TERM_SESSION_LIMIT=3
LONG_TERM_MEMORY_TOP_K=5
ENABLE_MEMORY_EXTRACTION=true
